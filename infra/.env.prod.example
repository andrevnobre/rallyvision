# ── Base de dados ──────────────────────────────────────────────────────────────
# Hostname é o nome do serviço Docker Compose
DATABASE_URL=postgresql://rally:TROCA_DB_PASSWORD@db:5432/rallyvision

# ── Redis / Celery ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── App ────────────────────────────────────────────────────────────────────────
# Gerar com: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=TROCA_POR_VALOR_ALEATORIO_LONGO

ENVIRONMENT=production
CORS_ORIGINS=https://bt-vision.com,https://www.bt-vision.com

# ── AWS / S3 (opcional — sem estas vars usa disco local) ───────────────────────
# Se preencheres, os vídeos são guardados no S3 em vez do disco da instância
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
S3_BUCKET=rallyvision-videos

# ── Postgres (usado pelo serviço db no compose) ────────────────────────────────
# Deve corresponder à password em DATABASE_URL acima
POSTGRES_USER=rally
POSTGRES_PASSWORD=TROCA_DB_PASSWORD
POSTGRES_DB=rallyvision

# ── GPU Spot Worker (opcional) ─────────────────────────────────────────────────
# Deixar em branco para usar Celery local (CPU). Preencher para ativar GPU spot.
SQS_URL=https://sqs.eu-west-1.amazonaws.com/124839183927/rallyvision-jobs
# Gerar com: python3 -c "import secrets; print(secrets.token_hex(32))"
WORKER_API_KEY=TROCA_POR_VALOR_ALEATORIO_LONGO
LAUNCH_TEMPLATE_ID=
INTERNAL_API_URL=https://api.bt-vision.com

# ── Admin ──────────────────────────────────────────────────────────────────────
# Email do utilizador que terá acesso ao painel /admin (definido no registo)
ADMIN_EMAIL=
